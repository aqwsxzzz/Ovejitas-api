# Database Configuration
# For local Docker dev, use these defaults:
DB_HOST=localhost
DB_PORT=5436
DB_NAME=ovejitas
DB_USER=username
DB_PASS=password
# For Render production, set individual vars from the Render PostgreSQL dashboard
# (DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS)

# JWT Configuration
JWT_SECRET=your-jwt-secret-here

# Environment
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Cookie Configuration (optional - for production)
# Set this to your domain for cross-subdomain cookies (e.g., .yourdomain.com)
# Leave empty for same-domain cookies
COOKIE_DOMAIN=

# Server Configuration
PORT=8081
HOST=0.0.0.0